package main

import (
	"fmt"
	"log"

	"gorm.io/driver/sqlite"
	"gorm.io/gorm"
	"gorm.io/gorm/logger"

	"trackcard-server/models"
	"trackcard-server/services"
)

func main() {
	// Initialize DB
	db, err := gorm.Open(sqlite.Open("trackcard.db"), &gorm.Config{
		Logger: logger.Default.LogMode(logger.Info),
	})
	if err != nil {
		log.Fatal("Failed to connect to database:", err)
	}

	// Initialize Services
	// services.InitGeocodingService() // Lazy initialized
	services.InitShipmentStageService(db)

	shipmentID := "260130000041"
	fmt.Printf("Regenerating stages for shipment: %s\n", shipmentID)

	// Regenerate stages
	stageSvc := services.GetShipmentStageService()
	if err := stageSvc.RegenerateStages(shipmentID); err != nil {
		log.Fatalf("Failed to regenerate stages: %v", err)
	}

	fmt.Println("Stages regenerated successfully.")

	// Verify extra_data
	var stages []models.ShipmentStage
	db.Where("shipment_id = ?", shipmentID).Order("stage_order ASC").Find(&stages)

	for _, s := range stages {
		fmt.Printf("Stage: %s (%s), PortCode: %s, ExtraData: %s\n", s.StageCode, models.GetStageName(s.StageCode), s.PortCode, s.ExtraData)
	}
}
